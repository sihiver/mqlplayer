<resources>

    <!-- Theme utama app -->
    <style name="Theme.MQLTV" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Samakan warna window awal dengan splash agar tidak ada flash putih sebelum splash muncul -->
        <item name="android:windowBackground">#0A1F3C</item>
    </style>

    <!--
        Splash Screen (androidx.core:core-splashscreen).
        - windowSplashScreenBackground    : background gelap sesuai tema app
        - windowSplashScreenAnimatedIcon  : ikon putih 108dp (terlihat di atas background gelap)
        - windowSplashScreenIconBackgroundColor : warna lingkaran di belakang ikon
        - postSplashScreenTheme           : tema setelah splash selesai
    -->
    <style name="Theme.MQLTV.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A1F3C</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">#1A3A6C</item>
        <item name="postSplashScreenTheme">@style/Theme.MQLTV</item>
    </style>

    <!-- Translucent overlay so channel list can appear without stopping playback underneath. -->
    <style name="Theme.MQLTV.ChannelListOverlay" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>